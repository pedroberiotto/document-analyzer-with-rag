# ─────────────────────────────────────────────────────────────
# Provider selection
#   llm_provider:       openai | ollama
#   embedding_provider: openai | ollama
# (embeddings must match between indexing and querying a document)
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# --- OpenAI (paid) ---
OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama (local, free) — `ollama serve` + `ollama pull <model>` ---
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434

# --- Retrieval / chunking (optional overrides) ---
# RETRIEVAL_K=5
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_FORMAT=console   # console | json
